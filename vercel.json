{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/nav/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/webcomponent/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    },
    {
      "source": "/common-nav.css",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/blogs/", "permanent": false },
    { "source": "/blogs", "destination": "/blogs/", "permanent": true },
    { "source": "/tutorials", "destination": "/tutorials/", "permanent": true },
    { "source": "/profile", "destination": "/profile/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/nav/(.*)", "destination": "/$1" },

    {
      "source": "/blogs/",
      "destination": "https://megamind-tutorials-vxcg.vercel.app/blogs/"
    },
    {
      "source": "/blogs/(.*)",
      "destination": "https://megamind-tutorials-vxcg.vercel.app/blogs/$1"
    },

    {
      "source": "/tutorials/",
      "destination": "https://megamind-tutorials-six.vercel.app/tutorials/"
    },
    {
      "source": "/tutorials/(.*)",
      "destination": "https://megamind-tutorials-six.vercel.app/tutorials/$1"
    },

    {
      "source": "/profile/",
      "destination": "https://megamind-profile-eta.vercel.app/profile/"
    },
    {
      "source": "/profile/(.*)",
      "destination": "https://megamind-profile-eta.vercel.app/profile/$1"
    },

    {
      "source": "/(.*)",
      "destination": "https://megamind-tutorials-six.vercel.app/$1"
    }
  ],
  "cleanUrls": true
}
