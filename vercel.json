{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/nav/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/webcomponent/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    },
    {
      "source": "/common-nav.css",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blogs", "destination": "/blogs/", "permanent": true },
    { "source": "/tutorials", "destination": "/tutorials/", "permanent": true },
    { "source": "/profile", "destination": "/profile/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/nav/:path*", "destination": "/:path*" },
    {
      "source": "/blogs/:path*",
      "destination": "https://megamind-tutorials-vxcg.vercel.app/blogs/:path*"
    },
    {
      "source": "/tutorials/:path*",
      "destination": "https://megamind-tutorials-six.vercel.app/tutorials/:path*"
    },
    {
      "source": "/profile/:path*",
      "destination": "https://megamind-profile-eta.vercel.app/profile/:path*"
    },
    {
      "source": "/",
      "destination": "https://megamind-tutorials-vxcg.vercel.app/blogs"
    },
    {
      "source": "/:path*",
      "destination": "https://megamind-tutorials-vxcg.vercel.app/:path*"
    }
  ],
  "cleanUrls": true
}
